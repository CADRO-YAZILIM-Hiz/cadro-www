# Health check endpoint
@app.get("/health")
def health_check():
    try:
        # Database connection check
        db = SessionLocal()
        db.execute(text("SELECT 1"))
        db.close()
        return {"status": "healthy", "database": "connected"}
    except Exception as e:
        return {"status": "unhealthy", "database": "disconnected", "error": str(e)}

# Rate limiting
