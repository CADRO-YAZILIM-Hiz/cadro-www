se noch heute\\.</h2>\n    </div>\n    <div class=\"contact-actions\">\n      <a class=\"primary-button\" href=\"pricing\\.html\" data-i18n-key=\"btn_view_plans\"></a>\n      <a class=\"ghost-button\" href=\"mailto:info@cadro\\.io\">Vertrieb kontaktieren</a>\n    </div>\n  </div>\n</section>\n  `\"\"\"\n\nidx = content\\.find\\(de_masraf_old\\)\nif idx != -1:\n    content = content\\.replace\\(de_masraf_old, de_masraf_new, 1\\)\n    print\\(\"DE masraf: replaced\"\\)\nelse:\n    print\\(\"DE masraf: NOT FOUND\"\\)\n\nwith open\\('page-content\\.js', 'w'\\) as f:\n    f\\.write\\(content\\)\n\nprint\\(\"Done\"\\)\nPYEOF$/": {
